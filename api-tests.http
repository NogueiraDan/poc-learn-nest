###############################################################################
# Library Management System - REST API Tests (Fase 5)
# 
# Requisitos:
# 1. Instale a extensão "REST Client" no VS Code
# 2. Certifique-se de que a API está rodando (npm run start:dev)
# 3. Clique em "Send Request" acima de cada requisição
#
# FASE 4 - Autenticação:
# - Rotas públicas: GET (navegação anônima)
# - Rotas protegidas: POST/PATCH/DELETE (requer JWT)
# - Roles: ADMIN, LIBRARIAN, MEMBER
#
# FASE 5 - Consultas Avançadas:
# - Filtros combinados (search, category, author, year, etc)
# - Paginação (page, limit ou skip, take)
# - Ordenação (sortBy, sortOrder)
# - Respostas paginadas com metadados
###############################################################################

@baseUrl = http://localhost:3000
# Variável para armazenar o token JWT (será preenchida após login)
@token = seu_token_aqui

###############################################################################
# 🔐 AUTHENTICATION - Autenticação & Autorização
###############################################################################

### 1. Registrar novo usuário (MEMBER por padrão)
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "João Silva",
  "email": "joao.silva@example.com",
  "password": "senha123"
}

### 2. Registrar usuário LIBRARIAN
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Maria Bibliotecária",
  "email": "maria.bibliotecaria@example.com",
  "password": "senha123",
  "role": "LIBRARIAN"
}

### 3. Registrar usuário ADMIN
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Admin Sistema",
  "email": "admin@example.com",
  "password": "senha123",
  "role": "ADMIN"
}

### 4. Login (obter token JWT)
# IMPORTANTE: Copie o accessToken da resposta e cole na variável @token acima
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@example.com",
  "password": "senha123"
}

### 5. Buscar perfil do usuário autenticado
# Requer: Token JWT válido
GET {{baseUrl}}/auth/me
Authorization: Bearer {{token}}

### 6. Refresh Token (renovar access token)
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
  "refreshToken": "seu_refresh_token_aqui"
}

### 7. Testar rota protegida SEM token (deve retornar 401)
GET {{baseUrl}}/auth/me

###############################################################################
# 📚 BOOKS - Livros
###############################################################################

### 1. Listar todos os livros (PÚBLICO - sem auth)
GET {{baseUrl}}/books
Content-Type: application/json

### 2. Buscar livro por ID (PÚBLICO - sem auth)
GET {{baseUrl}}/books/1
Content-Type: application/json

### 3. Buscar livro inexistente (deve retornar 404)
GET {{baseUrl}}/books/999
Content-Type: application/json

### 4. Criar novo livro (PROTEGIDO - requer ADMIN ou LIBRARIAN)
POST {{baseUrl}}/books
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "The Phoenix Project",
  "isbn": "978-0988262508",
  "description": "A novel about IT, DevOps, and helping your business win.",
  "publicationYear": 2013,
  "totalCopies": 3,
  "availableCopies": 3,
  "categoryId": 3
}

### 5. Tentar criar livro SEM token (deve retornar 401)
POST {{baseUrl}}/books
Content-Type: application/json

{
  "title": "Livro Não Autorizado",
  "isbn": "111-1111111111",
  "publicationYear": 2024,
  "totalCopies": 1,
  "availableCopies": 1,
  "categoryId": 1
}

### 6. Atualizar livro (PROTEGIDO - requer ADMIN ou LIBRARIAN)
PATCH {{baseUrl}}/books/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "availableCopies": 4,
  "description": "Edição atualizada - Um manual essencial sobre código limpo"
}

### 7. Deletar livro
DELETE {{baseUrl}}/books/7
Content-Type: application/json
Authorization: Bearer {{token}}

###############################################################################
# 🔍 FASE 5 - CONSULTAS AVANÇADAS COM FILTROS E PAGINAÇÃO
###############################################################################

### 8. Buscar livros por texto (título, ISBN ou descrição)
GET {{baseUrl}}/books?search=clean
Content-Type: application/json

### 9. Buscar livros por categoria
GET {{baseUrl}}/books?categoryId=1
Content-Type: application/json

### 10. Buscar livros por autor
GET {{baseUrl}}/books?authorId=1
Content-Type: application/json

### 11. Buscar livros por range de ano (2020-2023)
GET {{baseUrl}}/books?yearFrom=2020&yearTo=2023
Content-Type: application/json

### 12. Buscar apenas livros disponíveis
GET {{baseUrl}}/books?available=true
Content-Type: application/json

### 13. Paginação - Página 1 com 5 livros por página
GET {{baseUrl}}/books?page=1&limit=5
Content-Type: application/json

### 14. Paginação - Página 2 com 5 livros por página
GET {{baseUrl}}/books?page=2&limit=5
Content-Type: application/json

### 15. Paginação alternativa - Skip 10, Take 5
GET {{baseUrl}}/books?skip=10&take=5
Content-Type: application/json

### 16. Ordenar por título (A-Z)
GET {{baseUrl}}/books?sortBy=title&sortOrder=asc
Content-Type: application/json

### 17. Ordenar por ano de publicação (mais recente primeiro)
GET {{baseUrl}}/books?sortBy=publicationYear&sortOrder=desc
Content-Type: application/json

### 18. Filtros combinados: busca + categoria + paginação + ordenação
GET {{baseUrl}}/books?search=design&categoryId=3&page=1&limit=10&sortBy=title&sortOrder=asc
Content-Type: application/json

### 19. Filtros combinados: autor + ano + disponíveis
GET {{baseUrl}}/books?authorId=2&yearFrom=2015&available=true
Content-Type: application/json

### 20. Buscar categorias por texto
GET {{baseUrl}}/categories?search=programa
Content-Type: application/json

### 21. Categorias paginadas (5 por página)
GET {{baseUrl}}/categories?page=1&limit=5
Content-Type: application/json

### 22. Categorias ordenadas por nome (Z-A)
GET {{baseUrl}}/categories?sortBy=name&sortOrder=desc
Content-Type: application/json

### 23. Buscar autores por texto
GET {{baseUrl}}/authors?search=martin
Content-Type: application/json

### 24. Autores paginados
GET {{baseUrl}}/authors?page=1&limit=5
Content-Type: application/json

### 25. Autores ordenados por nome
GET {{baseUrl}}/authors?sortBy=name&sortOrder=asc
Content-Type: application/json

###############################################################################
# 📂 CATEGORIES - Categorias
###############################################################################

